# Stellarouter smart-contract — contoh environment (AMAN di-commit)
# Salin ke `.env` lalu isi nilainya. File `.env` di-ignore git.

STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployer / treasury account
DEPLOYER_PUBLIC_KEY=G...
DEPLOYER_SECRET_KEY=S...   # RAHASIA — jangan pernah commit
