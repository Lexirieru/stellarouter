# ─── Stellarouter gateway — x402 config (AMAN di-commit; salin ke .env) ──────
PORT=3001
STELLAR_NETWORK=stellar:testnet
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet

# Recipient: G... account WITH a USDC trustline (menerima pembayaran per-call).
# Akun deployer kita sudah punya trustline USDC, jadi bisa dipakai:
STELLAR_RECIPIENT=GDYS2IMCFRSBIR2DDJV2E6TLEQI5A45SEBICIIXUDIAQIOC5IRUR7UTC

# OZ Channels API key (WAJIB) — testnet: https://channels.openzeppelin.com/testnet/gen
OZ_API_KEY=

# Harga flat per call (USDC 7 desimal; "$0.005" auto-convert)
X402_PRICE=$0.005

# Upstream LLM opsional (OpenAI-compatible). Kosong = gateway balikin mock.
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=

# ─── Hanya untuk examples/client.js (buyer) ──────────────────────────────────
# S... key dengan trustline + saldo USDC. JANGAN commit .env (sudah di-ignore).
PAYER_SECRET_KEY=
GATEWAY_URL=http://localhost:3001
